\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/03/01 NeurIPS 2026 local-compatible style]

\newif\if@neuripsfinal\@neuripsfinalfalse
\newif\if@preprint\@preprintfalse
\newif\if@submission\@submissiontrue
\newif\if@natbib\@natbibtrue
\newif\if@nonanonymous\@nonanonymousfalse

\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{nonatbib}{\@natbibfalse}
\DeclareOption{main}{}
